# Port and host for the Fastify server
PORT=8081
HOST=0.0.0.0

# Gemini internal build identifier (fallback provided in code)
# GEMINI_BL=boq_assistant-bard-web-server_20260525.09_p0

# Admin API key for external applications (e.g. LibreChat, NextChat).
# This key bypasses the database checks and is always accepted by the gateway.
# Must be standard format like sk-... to be accepted by other OpenAI-compatible software.
ADMIN_API_KEY=sk-proj-personal-gateway-admin-key-bypass-12345

# Supabase configuration for analytics and project management
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Optional: Google Gemini cookies (fallback checks cookies/cookie.txt)
# GEMINI_COOKIE=SID=...; HSID=...

